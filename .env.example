# ===========================================================================
# TradeOS AI Pump Reader — environment. Copy to .env and fill what you need.
# EVERYTHING is optional: with nothing set the bot runs paper + in-memory.
# ===========================================================================

# ---- Supabase persistence (optional) --------------------------------------
# Create a Supabase project, run infrastructure/supabase/schema.sql in the SQL
# editor, then paste the project URL + the SERVICE ROLE key (Settings > API).
# The SERVICE key is secret — backend only, never ship it to a browser.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---- Scanning (no keys needed — public market data) -----------------------
PUMP_SCAN_EXCHANGES=binance,mexc,bitget
PUMP_SCAN_INTERVAL_SECONDS=300

# ---- Real-time volume-acceleration entry trigger --------------------------
PUMP_VELOCITY_TICK_SECONDS=20
PUMP_VELOCITY_ACCEL_FACTOR=4
PUMP_VELOCITY_WATCH_MIN_SCORE=40

# ---- Auto-entry (paper). Live entry needs PUMP_EXEC_MODE=live + keys -------
PUMP_AUTO_ENTRY=true
PUMP_AUTO_ENTRY_USD=100
PUMP_PAPER_BALANCE=1000

# ---- Live / real-money trading (DANGER — opt-in) --------------------------
# Leave as paper until you have tested. To trade real money:
#   1) set PUMP_EXEC_MODE=live
#   2) set the exchange keys below — SPOT ONLY, NO WITHDRAWAL permission.
# The same keys are used (read-only) to show your real balance in the dashboard.
PUMP_EXEC_MODE=paper
PUMP_EXEC_EXCHANGES=mexc,bitget
PUMP_ACCOUNT_POLL_SECONDS=120

BINANCE_API_KEY=
BINANCE_SECRET=
MEXC_API_KEY=
MEXC_SECRET=
BITGET_API_KEY=
BITGET_SECRET=
BITGET_PASSWORD=

# ---- Telegram notifications (optional) ------------------------------------
# Create a bot with @BotFather -> token; get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Legacy compose services (not required for the pump-reader app) --------
POSTGRES_DB=tradeos_ai
POSTGRES_USER=tradeos
POSTGRES_PASSWORD=tradeos_dev_password
DATABASE_URL=postgresql+asyncpg://tradeos:tradeos_dev_password@postgres:5432/tradeos_ai
RISK_ENGINE_URL=http://risk-engine:8000
